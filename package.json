{
  "name": "transcribble",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "next build",
    "dev": "next dev",
    "helper:check": "node scripts/helper-check.mjs",
    "helper:install": "node scripts/helper-install.mjs",
    "helper:start": "node scripts/helper-start.mjs",
    "lint": "eslint .",
    "start": "next start",
    "test": "node --import tsx --test tests/**/*.test.ts",
    "typecheck": "node -e \"require('fs').rmSync('.next/types',{recursive:true,force:true})\" && next typegen && tsc --noEmit",
    "validate": "npm run lint && npm run typecheck && npm test && npm run build"
  },
  "dependencies": {
    "@ffmpeg/ffmpeg": "0.12.15",
    "@ffmpeg/util": "0.12.2",
    "@huggingface/transformers": "3.8.1",
    "@radix-ui/react-progress": "1.1.1",
    "@radix-ui/react-slot": "1.1.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.454.0",
    "next": "15.5.14",
    "react": "^19",
    "react-dom": "^19",
    "tailwind-merge": "^2.5.5",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.23.0",
    "eslint-config-next": "15.5.14",
    "postcss": "^8.5",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.20.6",
    "typescript": "^5"
  }
}
